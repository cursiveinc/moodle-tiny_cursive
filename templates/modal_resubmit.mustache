{{!
    @template tiny_authory_tech/modal_resubmit

    Modal template for the resubmit dialog in the Authory.tech TinyMCE plugin.
    This template displays a toast notification with a resubmit button an

    Example context (json):
    {
    }
}}
<div class="tiny_authory_tech-toast-body" id="authory_tech-toast-body">
    <span id="ToastTextContent">{{#str}}resubmit, tiny_authory_tech {{/str}} </span>
    <a href="#" id="authory_tech-resubmit" class="d-block btn btn-sm mt-2 border rounded">
        <span id="toastOverlay" class="d-none">{{#pix}}i/loading, core{{/pix}}</span>{{#str}}resubmitbtn, tiny_authory_tech{{/str}}
    </a>
</div>