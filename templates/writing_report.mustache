{{!
@template tiny_cursive/writing_report

Template to display a student's writing report and analytics.

Example context (json):
{
    "username": "John Smith",
    "total_word": "1250", 
    "total_time": "2h 15m",
    "avg_min": "45",
    "options": "options name",
    "userdata": [
        {
            "modulename": "Essay 1",
            "lastmodified": "2023-12-01",
            "analytics": "<button>View</button>",
            "download": "<button>Download</button>"
        }
    ]
}
}}

<div class=" shadow-sm card border-0 mb-4">
    <div class="p-4">
        <div class="row align-items-center px-5">
            <div class="col-md-8">
                <div class="d-flex align-items-center">
                    <div class="cursive-profile-avatar me-4">
                        {{{profile_pic}}}
                    </div>
                    <div>
                        <h2 class="mb-2 fw-bold text-dark">{{username}}</h2>
                        <p class="text-muted mb-2 fs-5">{{#str}}wad, tiny_cursive{{/str}}</p>
                        <div id="tiny_cursive-topcard-cname" class="d-flex flex-wrap gap-3">
                            <div class="d-flex align-items-center text-muted mr-3">
                                {{#pix}} book, tiny_cursive {{/pix}}
                                <span>{{coursename}}</span>
                            </div>
                            <div class="d-flex align-items-center text-muted">
                                {{#pix}} submissions, tiny_cursive {{/pix}}
                                <span>{{total_sub}} {{#str}}submission, tiny_cursive{{/str}}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-right">
                <div class="text-muted mb-1">{{#str}}last_updated, tiny_cursive{{/str}}</div>
                <div class="text-dark"><strong>{{lastupdate}}</strong></div>
            </div>
        </div>
    </div>
</div>
<div class="my-3" id="cursive-statistics">
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6 mb-md-3 mb-lg-0 mb-sm-3 mb-3">
            <div class="card cursive-stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="cursive-stat-icon cursive-icon-blue">
                        {{#pix}} writing, tiny_cursive {{/pix}}
                    </div>
                    <p class="text-muted mb-1 fw-medium">{{#str}}total_words, tiny_cursive{{/str}}</p>
                    <h3 class="text-primary fw-bold mb-1">{{total_word}}</h3>
                    <small class="text-muted text-capitalize">{{#str}}aas, tiny_cursive{{/str}}</small>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-md-3 mb-lg-0 mb-sm-3 mb-3">
            <div class="card cursive-stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="cursive-stat-icon cursive-icon-green">
                        {{#pix}} clock, tiny_cursive {{/pix}}
                    </div>
                    <p class="text-muted mb-1 fw-medium">{{#str}}total_time, tiny_cursive{{/str}}</p>
                    <h3 class="text-success fw-bold mb-1">{{total_time}} m</h3>
                    <small class="text-muted text-capitalize">{{#str}}awt, tiny_cursive{{/str}}</small>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-md-0 mb-sm-3 mb-3">
            <div class="card cursive-stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="cursive-stat-icon cursive-icon-purple">
                        {{#pix}} speed, tiny_cursive {{/pix}}
                    </div>
                    <p class="text-muted mb-1 fw-medium">{{#str}}aspd, tiny_cursive{{/str}}</p>
                    <h3 class="text-purple fw-bold mb-1" style="color: #7b1fa2;">{{avg_spd}} WPM</h3>
                    <small class="text-muted text-capitalize">{{#str}}words_per_minute, tiny_cursive{{/str}}</small>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card cursive-stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="cursive-stat-icon cursive-icon-orange">
                        {{#pix}} submission, tiny_cursive {{/pix}}
                    </div>
                    <p class="text-muted mb-1 fw-medium">{{#str}}total_subm, tiny_cursive{{/str}}</p>
                    <h3 class="fw-bold mb-1" style="color: #f57c00;">{{total_sub}}</h3>
                    <small class="text-muted text-capitalize">{{#str}}acc, tiny_cursive{{/str}}</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="filter">
    <div class="card cursive-card-custom mb-3">
        <div class="card-body">
            <div class="row align-items-center justify-content-between">
                <div class="col-md-3">
                    <div class="d-flex flex-column flex-lg-row align-items-center">
                        <label for="CursiveChartTypeSelect" class="form-label mb-0 me-3 fw-medium">{{#str}}ctype, tiny_cursive{{/str}}:</label>
                        <select class="custom-select" id="CursiveChartTypeSelect" data-chart="{{chartdata}}">
                            <option data-track="{{#str}}wpot, tiny_cursive{{/str}}" value="progress">{{#str}}wpot, tiny_cursive{{/str}}</option>
                            <option data-track="{{#str}}wsa_sub, tiny_cursive{{/str}}" value="speed">{{#str}}wsa, tiny_cursive{{/str}}</option>
                            <option data-track="{{#str}}eem_sub, tiny_cursive{{/str}}" value="effort">{{#str}}eem, tiny_cursive{{/str}}</option>
                            <option data-track="{{#str}}wbp_sub, tiny_cursive{{/str}}" value="behavior_pattern">{{#str}}wbp, tiny_cursive{{/str}}</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3 mt-3 mt-md-0 d-none" id="CursiveMetricControls">
                    <div class="d-flex flex-column flex-lg-row align-items-center">
                        <label for="CursiveMetricSelect" class="form-label mb-0 me-3 fw-medium">{{#str}}metric, tiny_cursive{{/str}}:</label>
                        <select class="custom-select" id="CursiveMetricSelect">
                            <option data-track="{{#str}}track_wpm, tiny_cursive{{/str}}" value="words_per_minute">{{#str}}words_per_minute_desc, tiny_cursive{{/str}}</option>
                            <option data-track="{{#str}}track_wc, tiny_cursive{{/str}}"  value="word_count">{{#str}}word_count, tiny_cursive{{/str}}</option>
                            <option data-track="{{#str}}track_es, tiny_cursive{{/str}}" value="effort">{{#str}}es, tiny_cursive{{/str}}</option>
                            <option data-track="{{#str}}track_rr, tiny_cursive{{/str}}" value="backspace_percent">{{#str}}rr, tiny_cursive{{/str}}</option>
                            <option data-track="{{#str}}track_cpm, tiny_cursive{{/str}}"  value="characters_per_minute">{{#str}}characters_per_minute, tiny_cursive{{/str}}</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3 my-3 my-md-0" id="CursiveMetricControls">
                    <div class="d-flex flex-column flex-lg-row align-items-center">
                        <label for="CursiveCourseSelect" class="form-label mb-0 me-3 fw-medium">{{#str}}course, tiny_cursive{{/str}}:</label>
                            {{{options}}}
                    </div>
                </div>
                <div class="col-md-3 text-md-end text-center text-md-right">
                    <button class="btn btn-primary btn-custom" id="expandChart">
                       {{#pix}}t/expanded, core {{/pix}} {{#str}}expand, tiny_cursive {{/str}}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="">
    <div class="card cursive-card-custom mb-4">
        <div class="card-body">
            <div class="mb-4">
                <h4 class="fw-bold text-dark mb-2" id="CursiveChartTitle">
                    <!-- Chart Title -->
                </h4>
                <p class="text-muted" id="CursiveChartDescription">
                    <!-- Chart Description -->
                </p>
            </div>
            <div class="cursive-cws-chart-container" id="CursiveChartContainer">
                <canvas id="CursvieMainChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="tiny_cursive-writing-report bg-white rounded">

    <div class="p-3">
        <h3>{{#str}}rwm, tiny_cursive{{/str}}</h3>
    </div>
    <div class="table-responsive">
        <table class="tiny_cursive-writing-report-table table">
            <thead>
                <tr>
                    <th>{{#str}}module_name, tiny_cursive{{/str}}</th>
                    <th>{{#str}}last_modified, tiny_cursive{{/str}}</th>
                    <th>{{#str}}analytics, tiny_cursive{{/str}}</th>
                    <th>{{#str}}download, tiny_cursive{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#userdata}}
                <tr class="tiny_cursive-writing-report-table-row">
                    <td>{{modulename}}</td>
                    <td>{{lastmodified}}</td>
                    <td>
                        {{{analytics}}}
                    </td>
                    <td>
                        {{{download}}}
                    </td>
                </tr>
                {{/userdata}}
                {{^userdata}}
                <tr>
                    <td colspan="4" class="text-center"> {{#str}}no_submission,tiny_cursive{{/str}}</td>
                </tr>
                {{/userdata}}
            </tbody>
        </table>
    </div>
</div>
</div>